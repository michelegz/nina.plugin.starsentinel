<ResourceDictionary
    x:Class="Michelegz.NINA.StarSentinel.Options"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:ninactrl="clr-namespace:NINA.CustomControlLibrary;assembly=NINA.CustomControlLibrary"
    xmlns:rules="clr-namespace:NINA.Core.Utility.ValidationRules;assembly=NINA.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--  This data template will be displayed in N.I.N.A. on the options->plugin tab with the datacontext of the TestPlugin instance  -->
    <!--  In order for this datatemplate to be picked correctly, the key has to follow the naming convention of <IPlugin.Name>_Options -->
    <!--  Furthermore the Resource Dictionary has to be exported via code behind export attributes  -->
    <DataTemplate x:Key="Star Sentinel_Options">
        <StackPanel Orientation="Vertical">
            <Grid DataContext="{Binding}" Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Exposure -->
                <TextBlock Grid.Row="0" Grid.Column="0"
               Text="Exposure tolerance"
               VerticalAlignment="Center"
               HorizontalAlignment="Right"/>
                <ninactrl:UnitTextBox Grid.Row="0" Grid.Column="2"
                        Text="{Binding ExposureTolerance}"
                         Unit="%"
                          ToolTip="Allowed tolerance for the exposure time before considering the reference star count as invalid and recalculating it from the acquired images"
                         />

                <!-- FOV -->
                <TextBlock Grid.Row="2" Grid.Column="0"
               Text="FOV tolerance"
               VerticalAlignment="Center"
               HorizontalAlignment="Right"/>
                <ninactrl:UnitTextBox Grid.Row="2" Grid.Column="2"
                Text="{Binding FovTolerance}" Unit="%" 
                 ToolTip="Allowed tolerance for the field of view before considering the reference star count as invalid and recalculating it from the acquired images"        
                         />

                <!-- Percentile -->
                <TextBlock Grid.Row="4" Grid.Column="0"
               Text="Star count reference percentile"
               VerticalAlignment="Center"
               HorizontalAlignment="Right"/>
                <ninactrl:UnitTextBox Grid.Row="4" Grid.Column="2"
               Text="{Binding ReferencePercentile}"
                Unit="%"
                ToolTip="Percentile used to calculate the reference star count from the acquired images"
                />

                <!-- Initial Samples -->
                <TextBlock Grid.Row="6" Grid.Column="0"
               Text="Initial samples"
               VerticalAlignment="Center"
               HorizontalAlignment="Right"/>
                <ninactrl:UnitTextBox Grid.Row="6" Grid.Column="2"
             Text="{Binding InitialSamples}" 
              ToolTip="Number of initial images to calculate the reference star count"
                         />
            </Grid>
        </StackPanel>
    </DataTemplate>
</ResourceDictionary>